{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Blackslate",
	"version": "0.1.0",
	"identifier": "com.ks.blackslate",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "",
				"width": 900,
				"height": 600,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"devtools": true,
				"transparent": true,
				"backgroundColor": "#141414"
			}
		],
		"security": {
			"csp": null
		},
		"macOSPrivateApi": true
	},
	"bundle": {
		"active": true,
		"targets": ["dmg"],
		"externalBin": ["binaries/rg"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns"
		]
	}
}
